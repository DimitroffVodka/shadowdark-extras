{{!-- Details Tab --}}
<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="details">
    {{!-- Cost Section --}}
    <fieldset class="potion-fieldset">
        <legend><i class="fas fa-coins"></i> {{localize "SHADOWDARK.item.cost"}}</legend>
        <div class="form-group">
            <label>Currency</label>
            <div class="cost-grid">
                <div class="cost-item">
                    <input type="number" name="system.cost.gp" value="{{system.cost.gp}}" min="0" />
                    <span>GP</span>
                </div>
                <div class="cost-item">
                    <input type="number" name="system.cost.sp" value="{{system.cost.sp}}" min="0" />
                    <span>SP</span>
                </div>
                <div class="cost-item">
                    <input type="number" name="system.cost.cp" value="{{system.cost.cp}}" min="0" />
                    <span>CP</span>
                </div>
            </div>
        </div>
    </fieldset>

    {{!-- Slots Section --}}
    <fieldset class="potion-fieldset">
        <legend><i class="fas fa-weight-hanging"></i> {{localize "SHADOWDARK.inventory.slots"}}</legend>
        <div class="slots-grid">
            <div class="form-group">
                <label>Quantity</label>
                <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" />
            </div>
            <div class="form-group">
                <label>Slots/Item</label>
                <input type="number" name="system.slots.slots_used" value="{{system.slots.slots_used}}" min="0" />
            </div>
            <div class="form-group">
                <label>Max/Slot</label>
                <input type="number" name="system.slots.per_slot" value="{{system.slots.per_slot}}" min="0" />
            </div>
            <div class="form-group">
                <label>Free Carry</label>
                <input type="number" name="system.slots.free_carry" value="{{system.slots.free_carry}}" min="0" />
            </div>
        </div>
    </fieldset>

    {{!-- Source Section --}}
    <fieldset class="potion-fieldset">
        <legend><i class="fas fa-book"></i> {{localize "SHADOWDARK.sheet.item.tab.source"}}</legend>
        <div class="form-group">
            <label>Source</label>
            <select name="system.source.title">
                <option value="">&nbsp;</option>
                {{#each sources}}
                <option value="{{uuid}}" {{#if (eq ../system.source.title uuid)}}selected{{/if}}>
                    {{name}}
                </option>
                {{/each}}
            </select>
        </div>
    </fieldset>

    {{!-- Identification Section (native SD 4.x) --}}
    <fieldset class="potion-fieldset">
        <legend><i class="fas fa-search"></i> Identification</legend>
        <div class="form-group">
            <label>Status</label>
            {{!-- The checkbox is presentational (pointer-events:none, no name); the
                  surrounding div carries the toggle action so a single click runs
                  system.toggleIdentified() with no form-change / label-activation
                  race. The checked state is reconciled on the post-toggle re-render. --}}
            <div class="checkbox-label" data-action="toggleIdentified" style="cursor: pointer;">
                <input type="checkbox" tabindex="-1" style="pointer-events: none;" {{#if
                    isUnidentified}}checked{{/if}} />
                <span>Unidentified</span>
            </div>
        </div>
        <div class="form-group">
            <label>{{#if isUnidentified}}Identified Name{{else}}Unidentified Name{{/if}}</label>
            <input type="text" name="system.identification.name" value="{{identificationName}}"
                placeholder="Unidentified Potion" />
            <p class="hint">
                {{#if isUnidentified}}
                The item's true name, restored to players when it is identified.
                {{else}}
                What players see while this item is unidentified. Toggling Unidentified swaps it
                with the item's real name and hides the item's effects.
                {{/if}}
            </p>
        </div>
    </fieldset>
</section>